www.veratt.ru {
	redir https://veratt.ru{uri} permanent
}

veratt.ru {
	encode zstd gzip

	@serviceWorker path /service-worker.js
	header @serviceWorker Cache-Control "no-cache"

	@appShell path / /index.html
	header @appShell Cache-Control "no-cache"

	handle /api {
		rewrite * /health
		reverse_proxy api:8787
	}

	handle_path /api/* {
		reverse_proxy api:8787
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
